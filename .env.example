# Copy this file, rename the copy to ".env", and fill in the required values.
# This file is used mainly by Docker Compose to pass environment variables
# into the application and database containers.
#
# Example:
# cp .env.example .env
#
# If you run the application directly from IntelliJ IDEA instead of Docker,
# configure these variables in your Run Configuration environment variables.

# PostgreSQL database credentials.
# These values are used when the database container is initialized.
POSTGRES_USER=stock_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=stock_analyzer_database

# Initial admin user credentials.
# The application creates this admin user on startup if no admin exists yet.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=someStrongPassword123

# Financial Modeling Prep API key.
# Create an account at Financial Modeling Prep and paste your generated API key here.
FMP_API_KEY=change_me

# JWT signing secret.
# Generate your own secret and paste it here.
# It must be at least 32 characters long for HS256.
# Example command:
# openssl rand -base64 32
JWT_SECRET=local-development-secret-key-must-have-at-least-32-characters